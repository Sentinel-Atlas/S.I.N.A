# S.I.N.A Environment Configuration
# Copy this file to .env and adjust values for your system

# ─── Paths ────────────────────────────────────────────────────────────────────
# Root data directory (all user content, models, maps, indexes live here)
SINA_DATA_DIR=/opt/sina/data

# ─── Server ───────────────────────────────────────────────────────────────────
# Backend API port
BACKEND_PORT=3001

# Frontend port (dev only; in production the backend serves the frontend)
FRONTEND_PORT=3000

# Bind address: 127.0.0.1 for local-only, 0.0.0.0 to expose on LAN
# WARNING: Only change to 0.0.0.0 if you explicitly want LAN access
BIND_ADDRESS=127.0.0.1

# ─── AI / Ollama ──────────────────────────────────────────────────────────────
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_DEFAULT_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# ─── Maps ─────────────────────────────────────────────────────────────────────
# Tile server (optional, for serving offline MBTiles)
TILE_SERVER_PORT=8080
TILE_SERVER_HOST=http://127.0.0.1:8080

# ─── Downloads ────────────────────────────────────────────────────────────────
# Maximum concurrent downloads
MAX_CONCURRENT_DOWNLOADS=2

# ─── Indexing ─────────────────────────────────────────────────────────────────
# Max chunk size for document splitting (tokens approx)
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ─── Node ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
