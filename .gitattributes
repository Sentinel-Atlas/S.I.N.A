# Enforce LF line endings for all text files.
# This prevents CRLF issues on Windows/WSL2 checkouts.
* text=auto eol=lf

# Shell scripts must always be LF — CRLF breaks bash execution
*.sh text eol=lf

# Explicitly mark binary files
*.png binary
*.jpg binary
*.ico binary
*.gz binary
*.zip binary
*.woff2 binary
*.woff binary
*.ttf binary
